{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bvp/stadium",
    "description": "BVP Stadium",
    "keywords": [
        "boatrace",
        "library"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "shimomo",
            "email": "bvp@shimomo.net"
        }
    ],
    "support": {
        "issues": "https://github.com/boatracevibeproject/stadium/issues",
        "source": "https://github.com/boatracevibeproject/stadium"
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.52",
        "phpunit/phpunit": "^12.5.8 || ^13.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "BVP\\Stadium\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BVP\\Stadium\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        }
    }
}
